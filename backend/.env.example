DATABASE_URL=postgresql://atlas:CHANGE_ME@localhost:5432/atlas_solar_justo

# Auth (fundacao RBAC - papeis Colaborador/Administrador, ver CLAUDE.md Secao 2
# e docs/DRF.md Secao 2). JWT_SECRET so tem default de dev em src/config/env.ts
# porque o projeto ainda nao tem deploy de producao (ver CLAUDE.md, Secao 8) -
# TROCAR por um valor forte e unico antes de qualquer deploy real.
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=8h

# CORS — URL(s) do frontend permitidas a chamar esta API, separadas por
# vírgula (ex: https://atlas-solar-justo.vercel.app). Vazio = libera qualquer
# origem (só seguro em dev local, onde o Vite já isola isso via proxy — ver
# vite.config.ts e src/app.ts). Definir sempre em produção.
FRONTEND_URL=
